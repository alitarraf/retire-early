# Copy to .env (gitignored) and fill in. SANDBOX/TEST values only in dev.
# Server-side vars are read by the Netlify functions in api/ and NEVER bundled.
# Only VITE_-prefixed vars reach the client bundle.

# ── Anthropic (the Ask chat proxy, §11) ──────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Stripe (Ask Pro, §10) — test mode ────────────────────────────────
STRIPE_SECRET_KEY=rk_test_...          # restricted key: Checkout+Customers+Billing Portal write
STRIPE_PRICE_ID=price_...              # the $7/mo recurring Price
STRIPE_WEBHOOK_SECRET=whsec_...        # from `stripe listen` (local) or the dashboard endpoint

# ── Supabase — SERVER (secret key bypasses RLS; never bundled) ────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SECRET_KEY=sb_secret_...

# ── Supabase — CLIENT (publishable key; safe in the bundle) ──────────
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# ── App ──────────────────────────────────────────────────────────────
APP_URL=http://localhost:8888          # Checkout success/cancel + portal return base
# ASK_ALLOWED_ORIGINS=https://yourapp.com   # optional CORS allowlist (comma-separated)
